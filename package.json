{
	"name": "mermaid-fixer",
	"version": "1.1.3",
	"description": "Repair Mermaid diagrams and Markdown tables in Obsidian notes.",
	"main": "main.js",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fyaic/Mermaid-Fixer-Plugin.git"
	},
	"bugs": {
		"url": "https://github.com/fyaic/Mermaid-Fixer-Plugin/issues"
	},
	"homepage": "https://github.com/fyaic/Mermaid-Fixer-Plugin#readme",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"mermaid",
		"markdown"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.28.1",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "1.12.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "4.1.9"
	}
}
